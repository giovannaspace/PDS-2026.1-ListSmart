        cursor.execute("SELECT * FROM itens WHERE idDonoItem = ?", (self.idLista,))
        linha = cursor.fetchall()
        conexao.close()

        valorTotalGeral = 0

        for linhas in linha:

            objetoItem = Item.paraTuplas(linhas)
            valorTotalGeral += objetoItem.calcularPreco()
        
        return valorTotalGeral or 0

    def calcularTotalMarcados(self):

