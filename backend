        l = cursor.fetchone()
        conexao.close()
        
        if l:
            #reconstruir a lista
            return listaFinanceira(l[1],l[2],l[3],l[5], idLista=l[0], dataLista=l[4])

        else:
            print("Não foi encontrada uma lista com esse nome\n")
            return None
 
    def calcularTotalGeral(self):

        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        cursor.execute("SELECT SUM(quantidade * precoUnitario) FROM itens WHERE idDonoItem = ?", (self.idLista,))
        totalGeral = cursor.fetchone()
        conexao.close()

        if totalGeral and totalGeral[0] is not None:
            self.valorTotalGeral = totalGeral[0]
        else:
            self.valorTotalGeral = 0

    def calcularTotalMarcados(self):

        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        cursor.execute("SELECT SUM(quantidade * precoUnitario) FROM itens WHERE idDonoItem = ? AND statusCompra = ?", (self.idLista,1))
        marcados = cursor.fetchone()
        conexao.close()

        if marcados and marcados[0] is not None:
            self.valorTotalMarcado = marcados[0]
        else:
            self.valorTotalMarcado = 0

    def calcularTotalPendentes(self):
        
        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        cursor.execute("SELECT SUM(quantidade * precoUnitario) FROM itens WHERE idDonoItem = ? AND statusCompra = ?", (self.idLista,0))
        naoMarcados = cursor.fetchone()
        conexao.close()

        if naoMarcados and naoMarcados[0] is not None:
            self.valorTotalPendentes = naoMarcados[0]
        else:
            self.valorTotalPendentes = 0

    def calcularTetoOrcamentario(self):
        if self.valorTotalMarcado > self.tetoOrcamentario:
            diferenca = self.tetoOrcamentario - self.valorTotalMarcado
            print(f"ALERTA: O valor ultrapassou o limite em R$ {diferenca:.2f}!")
        elif self.valorTotalMarcado == self.tetoOrcamentario:
            print(f"ATENÇÃO: Você atingiu exatamente o limite de R$ {self.tetoOrcamentario :.2f}!")
        else:
            diferenca = self.valorTotalMarcado - self.tetoOrcamentario
            print(f"Dentro do orçamento. Você ainda pode gastar R$ {diferenca:.2f}!")


class Item():
    def __init__(self,nomeItem, quantidade, unidade, precoUnitario, desconto,observacoesItem,categorias,idDonoItem,idItem=None):

        self.nomeItem = nomeItem
        self.quantidade = quantidade
        self.unidade = unidade
        self.precoUnitario = precoUnitario
        self.desconto = desconto
        self.observacoesItem = observacoesItem
        self.statusCompra = 0
        self.idItem = idItem if idItem else str(uuid.uuid4())
        self.idDonoItem = idDonoItem
        self.idCategoria = categorias

    def aplicarDesconto(self):
        print("Digite o tipo de desconto")
        print("1 - Porcentagem Fixa\n2 - Promoção Progressiva (Leve X pague Y)")
        
        aux = 0

        opcao = input("Opção: ")
        if opcao == "1":

            aux = 1

            print("Qual a porcentagem de desconto?")
            porcentagem = float(input("Porcentagem: "))

            self.desconto = self.precoUnitario * (porcentagem/100)
        elif opcao == "2":
            
            aux = 2

            print("Leve X por Y")
            x = int(input("X: "))
            y = float(input("Y: "))

            semDesconto = self.precoUnitario * x
            self.desconto = (semDesconto - y) / x

        copiaPrecoUnitario = self.precoUnitario
        self.precoUnitario -= self.desconto

        if aux == 1:
            aux = 0
        elif aux == 2:
            aux = 1

        ##Atualizando no BD
        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        cursor.execute("""UPDATE itens SET precoUnitario = ?, desconto = ?, precoOriginal = ?
                         WHERE idItem = ? AND idDonoItem = ? """, 
                         (self.precoUnitario,aux,copiaPrecoUnitario,self.idItem,self.idDonoItem))
        conexao.commit()
        conexao.close()

    def atualizarItem(self,campo,valorNovo):
        
        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        
        if campo == "nome":
            nome = "UPDATE itens SET nomeItem = ? WHERE idDonoItem = ? AND idItem = ?" 
            cursor.execute(nome,(valorNovo,self.idDonoItem,self.idItem))
            conexao.commit()

        elif campo == "nota":
            nota = "UPDATE itens SET observacoesItem = ? WHERE idDonoItem = ? AND idItem = ?" 
            cursor.execute(nota,(valorNovo,self.idDonoItem,self.idItem))
            conexao.commit()

        elif campo == "precoUnitario":
            precoUnitario = "UPDATE itens SET precoUnitario = ? WHERE idDonoItem = ? AND idItem = ?" 
            cursor.execute(precoUnitario,(valorNovo,self.idDonoItem,self.idItem))
            conexao.commit()
        
        elif campo == "unidade":
            unidade = "UPDATE itens SET unidade = ? WHERE idDonoItem = ? AND idItem = ?" 
            cursor.execute(unidade,(valorNovo,self.idDonoItem,self.idItem))
            conexao.commit()

        else:
            conexao.close()
            return

        conexao.close()

    def removerItem(self):
        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        cursor.execute("DELETE FROM itens WHERE idDonoItem = ? AND idItem = ?", (self.idDonoItem,self.idItem))

        conexao.commit()
        conexao.close()
 
    ##Essa parte de quantidade precisa ter atenção quando desconto X por Y
    def quantidadeItem(self, opecacao):
        conexao = sqlite3.connect("banco.db")
        conexao.execute("PRAGMA foreign_keys = ON")
        cursor = conexao.cursor()

        cursor.execute("SELECT desconto, precoOriginal, quantidade FROM itens WHERE idDonoItem = ? AND idItem = ?",(self.idDonoItem,self.idItem))
        item = cursor.fetchone()
        conexao.close()

        if item:
            desconto = item[0]
            precoOriginal = item[1]
            quantidade = item[2]

        if opecacao == "+":
            if desconto == 1:
                ## É com desconto
                idCopia = str(uuid.uuid4())
                copiaItem = Item(self.nomeItem,1,self.unidade,precoOriginal,0,self.observacoesItem,0,
                                 self.idDonoItem,idCopia)
                ItemNovaBD(copiaItem)

            else:
                ## Sem desconto X por Y
                conexao = sqlite3.connect("banco.db")
                cursor = conexao.cursor()

                quantidadeNova = quantidade + 1
                cursor.execute("UPDATE itens SET quantidade = ? WHERE idDonoItem = ? AND idItem = ?",
                                (quantidadeNova,self.idDonoItem, self.idItem))
                conexao.commit()
                conexao.close()

        elif opecacao == "-":
            if desconto == 1:
                print("Deseja remover este Item com desconto?")
                opcao = str(input("sim ou nao? "))
                if opcao == "sim":
                    self.removerItem()
                else:
                    pass

            else:
                if quantidade == 1:
                    print("Deseja remover o Item?")
                    opcao = str(input("sim ou nao? "))
                    if opcao == "sim":
                        self.removerItem()
                    else:
                        pass

                elif quantidade > 1:

                    conexao = sqlite3.connect("banco.db")
                    cursor = conexao.cursor()

                    quantidadeNova = quantidade - 1
                    cursor.execute("UPDATE itens SET quantidade = ? WHERE idDonoItem = ? AND idItem = ?",
                                    (quantidadeNova,self.idDonoItem, self.idItem))
                    conexao.commit()
                    conexao.close()

